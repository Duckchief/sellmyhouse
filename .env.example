# Database
DATABASE_URL="postgresql://smh:smh_dev@localhost:5432/smh_dev"
DATABASE_URL_TEST="postgresql://smh:smh_test@localhost:5433/smh_test"

# Session
SESSION_SECRET="change-me-to-a-random-64-char-string"

# AI Providers (only active provider key required)
AI_ANTHROPIC_API_KEY=""
AI_OPENAI_API_KEY=""
AI_GOOGLE_API_KEY=""

# WhatsApp
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_VERIFY_TOKEN=""
# Meta WhatsApp Business API webhook verification token (required)
# Webhook signature verification is unconditional — server will not start
# without this value set
