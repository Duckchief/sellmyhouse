# Email (SMTP)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@sellmyhouse.sg"

# Encryption
ENCRYPTION_KEY=""

# JWT — dedicated secret for unsubscribe tokens and other JWT operations
# Must be a separate 32+ byte random string — never reuse SESSION_SECRET
JWT_SECRET=""

# HDB Data
DATAGOV_API_KEY=""

# App
NODE_ENV="development"
PORT=3000
BASE_URL="http://localhost:3000"
