{
  "name": "sellmyhomenow-v2",
  "version": "2.0.0",
  "description": "AI-powered HDB resale transaction platform",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias && npm run build:css",
    "build:css": "tailwindcss -i src/views/styles/input.css -o public/css/output.css --minify",
    "dev": "node -e \"require('child_process').execSync('lsof -ti :3000 | xargs kill -9', {stdio:'ignore'})\" ; concurrently \"tsc --watch\" \"tsc-alias --watch\" \"tailwindcss -i src/views/styles/input.css -o public/css/output.css --watch\" \"nodemon dist/server.js\"",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.ts",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "docker:dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up",
    "docker:test:db": "docker compose -f docker/docker-compose.test.yml up -d",
    "docker:test:db:down": "docker compose -f docker/docker-compose.test.yml down"
  },
  "keywords": [
    "hdb",
    "resale",
    "property",
    "singapore"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.19.2",
    "@types/jsonwebtoken": "^9.0.10",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "csv-parse": "^6.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "file-type": "^16.5.4",
    "helmet": "^8.1.0",
    "htmx.org": "2.0.4",
    "i18next": "^25.8.17",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "nunjucks": "^3.2.4",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^7.0.11",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
