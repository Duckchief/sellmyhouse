{% extends "layouts/admin.njk" %}

{% block content %}
{% set pageTitle = "Analytics Dashboard" %}
{% set pageSubtitle = "Platform performance overview" %}
{% include "partials/shared/page-header.njk" %}

<div id="analytics-content">
  {% include "partials/admin/analytics.njk" %}
</div>

<script nonce="{{ cspNonce }}">
(function () {
  function setPreset(name) {
    var today = new Date();
    var pad = function (n) { return String(n).padStart(2, '0'); };
    var fmt = function (d) { return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()); };
    var todayStr = fmt(today);
    var from;

    if (name === 'this-week') {
      var d = new Date(today);
      var day = d.getDay() || 7;
      d.setDate(d.getDate() - day + 1);
      from = fmt(d);
    } else if (name === 'this-month') {
      from = fmt(new Date(today.getFullYear(), today.getMonth(), 1));
    } else if (name === '3-months') {
      var d3 = new Date(today);
      d3.setMonth(d3.getMonth() - 3);
      from = fmt(d3);
    } else if (name === '6-months') {
      var d6 = new Date(today);
      d6.setMonth(d6.getMonth() - 6);
      from = fmt(d6);
    } else if (name === 'ytd') {
      from = fmt(new Date(today.getFullYear(), 0, 1));
    }

    document.getElementById('dateFrom').value = from;
    document.getElementById('dateTo').value = todayStr;
    document.getElementById('preset').value = name;
    htmx.trigger(document.getElementById('filterBtn'), 'click');
  }

  var analyticsEl = document.getElementById('analytics-content');

  analyticsEl.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-preset]');
    if (btn) setPreset(btn.getAttribute('data-preset'));
  });

  function initCharts() {
    var leadDataEl = document.getElementById('leadSourceData');
    var leadCtx = document.getElementById('leadSourceChart');
    if (leadCtx && leadDataEl) {
      var existing = Chart.getChart(leadCtx);
      if (existing) existing.destroy();
      var leadData = JSON.parse(leadDataEl.textContent);
      var leadLabels = Object.keys(leadData);
      var leadValues = leadLabels.map(function (k) { return leadData[k].total; });
      new Chart(leadCtx, {
        type: 'doughnut',
        data: {
          labels: leadLabels,
          datasets: [{ data: leadValues, backgroundColor: ['#c8553d', '#1a1a2e', '#3b82f6', '#22c55e', '#eab308'] }],
        },
        options: { plugins: { legend: { position: 'bottom' } } },
      });
    }

    var timeDataEl = document.getElementById('timeToCloseData');
    var timeCtx = document.getElementById('timeToCloseChart');
    if (timeCtx && timeDataEl) {
      var existing2 = Chart.getChart(timeCtx);
      if (existing2) existing2.destroy();
      var timeData = JSON.parse(timeDataEl.textContent);
      var timeLabels = Object.keys(timeData);
      var timeValues = timeLabels.map(function (k) { return timeData[k].averageDays; });
      new Chart(timeCtx, {
        type: 'bar',
        data: {
          labels: timeLabels,
          datasets: [{ label: 'Days', data: timeValues, backgroundColor: '#c8553d' }],
        },
        options: {
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true } },
        },
      });
    }
  }

  initCharts();
  analyticsEl.addEventListener('htmx:afterSettle', initCharts);
})();
</script>
{% endblock %}
