{% extends "layouts/admin.njk" %}

{% block content %}
{% set pageTitle = "All Sellers" %}
{% include "partials/shared/page-header.njk" %}

{% set hxEndpoint = '/admin/sellers' %}
{% set formId = 'admin-seller-filter-form' %}
{% include "partials/shared/seller-status-pills.njk" %}

<form id="admin-seller-filter-form" class="flex gap-3 mb-6">
  <input type="hidden" name="status" id="status-input" value="{{ currentStatus }}" />
  <input type="text" name="search" placeholder="{{ 'Search by name, email, phone' | t }}" class="border rounded px-3 py-2 text-sm flex-1" value="{{ currentSearch }}"
    hx-get="/admin/sellers" hx-trigger="input changed delay:300ms" hx-target="#seller-list" hx-include="[name=status],[name=agentId]" />
  <select name="agentId" class="border rounded px-3 py-2 text-sm"
    hx-get="/admin/sellers" hx-trigger="change" hx-target="#seller-list" hx-include="[name=status],[name=search]">
    <option value="">{{ "All Agents" | t }}</option>
    <option value="unassigned" {% if currentAgentId == 'unassigned' %}selected{% endif %}>{{ "Unassigned" | t }}</option>
    <option disabled>─────────</option>
    {% for agent in team %}
      {% if agent.isActive %}
        <option value="{{ agent.id }}" {% if currentAgentId == agent.id %}selected{% endif %}>{{ agent.name }}</option>
      {% endif %}
    {% endfor %}
  </select>
</form>
<div id="action-result" class="mb-4"></div>
<div id="modal-container"></div>
<div id="seller-list" hx-get="/admin/sellers" hx-trigger="sellerAssigned from:body" hx-target="#seller-list" hx-swap="innerHTML">{% include "partials/admin/seller-list.njk" %}</div>
{% endblock %}
