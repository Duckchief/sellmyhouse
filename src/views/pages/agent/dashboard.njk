{% extends "layouts/agent.njk" %}

{% block content %}
{% set pageTitle = "Pipeline Overview" %}
{% include "partials/shared/page-header.njk" %}

{# Pipeline cards auto-refresh #}
<div id="pipeline-cards"
     hx-get="/agent/dashboard/stats{% if currentStage %}?stage={{ currentStage }}{% endif %}"
     hx-trigger="every 30s"
     hx-swap="innerHTML">
  {% include "partials/agent/pipeline-cards.njk" %}
</div>

{# Full pipeline content (loaded once, not auto-refreshed) #}
<div id="pipeline-content">
  {% include "partials/agent/pipeline-overview.njk" %}
</div>
{% endblock %}
