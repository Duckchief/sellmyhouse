{% extends "layouts/public.njk" %}

{% block title %}{{ "Set Up Two-Factor Authentication" | t }} — SellMyHouse{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-6">{{ "Two-Factor Authentication" | t }}</h1>

  {% if not showConfirm %}
    <p class="text-gray-600 mb-4">{{ "Secure your account with an authenticator app." | t }}</p>
    <form hx-post="/auth/2fa/setup" hx-target="#setup-content" hx-swap="innerHTML">
      <button type="submit"
        class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        {{ "Enable 2FA" | t }}
      </button>
    </form>
  {% endif %}

  <div id="setup-content">
    {% if showConfirm %}
      <div class="space-y-6">
        <div>
          <p class="text-sm text-gray-600 mb-3">{{ "Scan this QR code with your authenticator app:" | t }}</p>
          <div class="flex justify-center">
            <img src="{{ qrCodeDataUrl }}" alt="QR Code" class="w-48 h-48" />
          </div>
        </div>

        <div>
          <h2 class="text-lg font-semibold mb-2">{{ "Backup Codes" | t }}</h2>
          <p class="text-sm text-gray-600 mb-2">{{ "Save these codes in a safe place. Each can only be used once." | t }}</p>
          <div class="bg-gray-50 rounded-md p-4 font-mono text-sm grid grid-cols-2 gap-2">
            {% for code in backupCodes %}
              <div>{{ code }}</div>
            {% endfor %}
          </div>
        </div>

        <form hx-post="/auth/2fa/verify" hx-target="#verify-messages" hx-swap="innerHTML" class="space-y-4">
          <div id="verify-messages"></div>
          <div>
            <label for="token" class="block text-sm font-medium text-gray-700">{{ "Enter code from your app to confirm:" | t }}</label>
            <input type="text" id="token" name="token" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
          </div>
          <button type="submit"
            class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            {{ "Verify & Activate" | t }}
          </button>
        </form>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
