{% extends "layouts/public.njk" %}

{% block title %}{{ "Verify Two-Factor Authentication" | t }} — SellMyHomeNow{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-6">{{ "Two-Factor Verification" | t }}</h1>

  {% if error %}
    <div class="mb-4 rounded-md bg-red-50 p-4">
      <p class="text-sm text-red-700">{{ error }}</p>
    </div>
  {% endif %}

  <div id="totp-section">
    <p class="text-gray-600 mb-4">{{ "Enter the 6-digit code from your authenticator app." | t }}</p>

    <form
      hx-post="/auth/2fa/verify"
      hx-target="#totp-messages"
      hx-swap="innerHTML"
      class="space-y-4"
    >
      <div id="totp-messages"></div>

      <div>
        <label for="token" class="block text-sm font-medium text-gray-700">{{ "Verification Code" | t }}</label>
        <input type="text" id="token" name="token" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code"
          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-center text-2xl tracking-widest" />
      </div>

      <button type="submit"
        class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        {{ "Verify" | t }}
      </button>
    </form>
  </div>

  <div class="mt-6 border-t pt-4">
    <button id="toggle-backup" onclick="toggleBackup()" class="text-sm text-indigo-600 hover:text-indigo-500">
      {{ "Use a backup code instead" | t }}
    </button>

    <div id="backup-section" class="hidden mt-4">
      <form
        hx-post="/auth/2fa/backup"
        hx-target="#backup-messages"
        hx-swap="innerHTML"
        class="space-y-4"
      >
        <div id="backup-messages"></div>

        <div>
          <label for="code" class="block text-sm font-medium text-gray-700">{{ "Backup Code" | t }}</label>
          <input type="text" id="code" name="code" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 font-mono" />
        </div>

        <button type="submit"
          class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
          {{ "Verify Backup Code" | t }}
        </button>
      </form>
    </div>
  </div>
</div>

<script>
function toggleBackup() {
  var section = document.getElementById('backup-section');
  section.classList.toggle('hidden');
}
</script>
{% endblock %}
