{% extends "layouts/public.njk" %}

{% block title %}{{ "Forgot Password" | t }} — SellMyHomeNow{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-2">{{ "Reset Your Password" | t }}</h1>
  <p class="text-sm text-gray-600 mb-6">
    {{ "Enter your email address and we'll send you a reset link." | t }}
  </p>

  {% if error %}
  <div class="mb-4 rounded-md bg-red-50 p-4">
    <p class="text-sm text-red-700">{{ error }}</p>
  </div>
  {% endif %}

  {% if success %}
  <div class="rounded-md bg-green-50 border border-green-200 p-4">
    <p class="text-sm text-green-800">{{ success }}</p>
  </div>
  {% else %}
  <div id="forgot-messages"></div>

  <form
    hx-post="/auth/forgot-password"
    hx-target="#forgot-messages"
    hx-swap="innerHTML"
    class="space-y-4"
  >
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700">
        {{ "Email address" | t }}
      </label>
      <input type="email" id="email" name="email" required autocomplete="email"
             class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
    </div>

    <button type="submit"
            class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
      {{ "Send Reset Link" | t }}
    </button>
  </form>
  {% endif %}

  <p class="mt-4 text-center text-sm text-gray-600">
    <a href="/auth/login" class="font-medium text-indigo-600 hover:text-indigo-500">
      {{ "Back to login" | t }}
    </a>
  </p>
</div>
{% endblock %}
