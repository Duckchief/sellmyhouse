{% extends "layouts/public.njk" %}

{% block title %}{{ "Register" | t }} — SellMyHouse{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-6">{{ "Create Your Account" | t }}</h1>

  <form
    hx-post="/auth/register"
    hx-target="#form-messages"
    hx-swap="innerHTML"
    class="space-y-4"
  >
    <div id="form-messages"></div>

    <div>
      <label for="name" class="block text-sm font-medium text-gray-700">{{ "Full Name" | t }}</label>
      <input type="text" id="name" name="name" required
        value="{{ values.name if values }}"
        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
      {% if errors and errors.name %}
        <p class="mt-1 text-sm text-red-600">{{ errors.name }}</p>
      {% endif %}
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700">{{ "Email" | t }}</label>
      <input type="email" id="email" name="email" required
        value="{{ values.email if values }}"
        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
      {% if errors and errors.email %}
        <p class="mt-1 text-sm text-red-600">{{ errors.email }}</p>
      {% endif %}
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium text-gray-700">{{ "Phone Number" | t }}</label>
      <input type="tel" id="phone" name="phone" required placeholder="91234567"
        value="{{ values.phone if values }}"
        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
      {% if errors and errors.phone %}
        <p class="mt-1 text-sm text-red-600">{{ errors.phone }}</p>
      {% endif %}
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-gray-700">{{ "Password" | t }}</label>
      <input type="password" id="password" name="password" required minlength="8"
        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
      {% if errors and errors.password %}
        <p class="mt-1 text-sm text-red-600">{{ errors.password }}</p>
      {% endif %}
    </div>

    <div class="space-y-2">
      <div class="flex items-start">
        <input type="checkbox" id="consentService" name="consentService" value="true" required
          class="mt-1 h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
        <label for="consentService" class="ml-2 text-sm text-gray-600">
          {{ "I consent to SellMyHouse collecting and processing my personal data for the purpose of facilitating my HDB resale transaction." | t }} <span class="text-red-500">*</span>
        </label>
      </div>

      <div class="flex items-start">
        <input type="checkbox" id="consentMarketing" name="consentMarketing" value="true"
          class="mt-1 h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
        <label for="consentMarketing" class="ml-2 text-sm text-gray-600">
          {{ "I consent to receiving marketing communications about property-related services and promotions." | t }}
        </label>
      </div>
    </div>

    <button type="submit"
      class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
      {{ "Register" | t }}
    </button>
  </form>

  <p class="mt-4 text-center text-sm text-gray-600">
    {{ "Already have an account?" | t }}
    <a href="/auth/login" class="font-medium text-indigo-600 hover:text-indigo-500">{{ "Log in" | t }}</a>
  </p>
</div>
{% endblock %}
