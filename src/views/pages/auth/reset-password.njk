{% extends "layouts/public.njk" %}

{% block title %}{{ "Reset Password" | t }} — SellMyHomeNow{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-2">{{ "Choose a New Password" | t }}</h1>
  <p class="text-sm text-gray-600 mb-6">
    {{ "Your new password must be at least 8 characters and contain at least one number." | t }}
  </p>

  {% if error %}
  <div class="mb-4 rounded-md bg-red-50 p-4">
    <p class="text-sm text-red-700">{{ error }}</p>
  </div>
  {% endif %}

  <div id="reset-messages"></div>

  <form
    action="/auth/reset-password/{{ token }}"
    method="POST"
    hx-post="/auth/reset-password/{{ token }}"
    hx-target="#reset-messages"
    hx-swap="innerHTML"
    onsubmit="return checkPasswords()"
    class="space-y-4"
  >
    <div>
      <label for="password" class="block text-sm font-medium text-gray-700">
        {{ "New Password" | t }}
      </label>
      <input type="password" id="password" name="password" required
             minlength="8" autocomplete="new-password"
             class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
    </div>

    <div>
      <label for="confirmPassword" class="block text-sm font-medium text-gray-700">
        {{ "Confirm New Password" | t }}
      </label>
      <input type="password" id="confirmPassword" name="confirmPassword" required
             minlength="8" autocomplete="new-password"
             class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
      <p id="password-mismatch" class="hidden mt-1 text-xs text-red-600">
        {{ "Passwords do not match." | t }}
      </p>
    </div>

    <button type="submit"
            class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
      {{ "Set New Password" | t }}
    </button>
  </form>

  <p class="mt-4 text-center text-sm text-gray-600">
    <a href="/auth/login" class="font-medium text-indigo-600 hover:text-indigo-500">
      {{ "Back to login" | t }}
    </a>
  </p>
</div>

<script>
function checkPasswords() {
  var pw = document.getElementById('password').value;
  var confirm = document.getElementById('confirmPassword').value;
  var msg = document.getElementById('password-mismatch');
  if (pw !== confirm) {
    msg.classList.remove('hidden');
    return false;
  }
  msg.classList.add('hidden');
  return true;
}
</script>
{% endblock %}
