{% extends "layouts/seller.njk" %}

{% block content %}
<div class="max-w-4xl mx-auto">
  {% set pageTitle = "Property Photos" %}
  {% set pageSubtitle = "Upload up to 20 high-quality photos of your property. Minimum 800px, JPG or PNG only, max 5MB each." %}
  {% include "partials/shared/page-header.njk" %}

  <div id="photo-upload-container">
    {% include "partials/seller/photo-upload-area.njk" %}
  </div>

  <div id="photo-grid-container" class="mt-8">
    {% include "partials/seller/photo-grid.njk" %}
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js" nonce="{{ cspNonce }}"></script>
{% endblock %}
