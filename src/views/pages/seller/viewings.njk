{% extends "layouts/seller.njk" %}

{% block head %}
<script src="/js/viewing-calendar.js" nonce="{{ cspNonce }}"></script>
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">
  {% set pageTitle = "Viewings" %}
  {% set pageSubtitle = "Manage viewing slots and track booked viewings for your property." %}
  {% include "partials/shared/page-header.njk" %}

  <div id="viewings-container">
    {% include "partials/seller/viewings-dashboard.njk" %}
  </div>
</div>

{# Cancel slot confirmation modal (hidden by default) #}
<div id="cancel-slot-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-xl shadow-xl max-w-sm w-full p-6">
    <p class="text-sm text-gray-700 mb-6">{{ "Cancel this slot and notify any booked viewers?" | t }}</p>
    <div class="flex gap-3 justify-end">
      <button type="button"
              data-action="close-cancel-slot-modal"
              class="px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">
        {{ "Cancel" | t }}
      </button>
      <button type="button"
              id="cancel-slot-confirm-btn"
              class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700">
        {{ "OK" | t }}
      </button>
    </div>
  </div>
</div>
{% endblock %}
