<div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50" id="cdd-modal">
  <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
    <h3 class="text-lg font-semibold mb-4">{{ title | default("Create CDD Record") | t }}</h3>

    <div id="cdd-modal-error" class="hidden mb-3 p-3 bg-red-50 text-red-700 text-sm rounded"></div>

    <form
      hx-post="{{ endpoint | default('/agent/sellers/' + sellerId + '/cdd') }}"
      hx-target="{{ target | default('#compliance-cdd-card') }}"
      hx-swap="outerHTML"
      data-remove-on-success="cdd-modal"
      data-error-target="cdd-modal-error"
      data-error-message="{{ 'An error occurred. Please check the form and try again.' | t }}"
    >
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">{{ "Full Name" | t }} <span class="text-red-500">*</span></label>
          <input type="text" name="fullName" required
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="{{ 'Full legal name' | t }}">
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "NRIC Last 4 Characters" | t }} <span class="text-red-500">*</span></label>
          <input type="text" name="nricLast4" required maxlength="4" minlength="4"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="{{ 'e.g. 567A' | t }}">
          <p class="text-xs text-gray-500 mt-1">{{ "Only the last 4 characters are stored (PDPA compliance)" | t }}</p>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Date of Birth" | t }}</label>
          <input type="date" name="dateOfBirth"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Nationality" | t }}</label>
          <input type="text" name="nationality"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="{{ 'e.g. Singaporean' | t }}">
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Occupation" | t }}</label>
          <input type="text" name="occupation"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Risk Level" | t }}</label>
          <div class="flex gap-4">
            <label class="inline-flex items-center">
              <input type="radio" name="riskLevel" value="standard" checked class="mr-2">
              <span class="text-sm">{{ "Standard" | t }}</span>
            </label>
            <label class="inline-flex items-center">
              <input type="radio" name="riskLevel" value="enhanced" class="mr-2">
              <span class="text-sm">{{ "Enhanced" | t }}</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Notes" | t }}</label>
          <textarea name="notes" rows="3"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="{{ 'Additional notes (required for enhanced risk)' | t }}"></textarea>
        </div>
      </div>

      <div class="flex gap-3 justify-end mt-6">
        <button
          type="button"
          data-action="remove-element"
          data-target="cdd-modal"
          class="px-4 py-2 text-sm border rounded hover:bg-gray-50">
          {{ "Cancel" | t }}
        </button>
        <button
          type="submit"
          class="px-4 py-2 text-sm bg-indigo-600 text-white rounded hover:bg-indigo-700">
          {{ "Create CDD Record" | t }}
        </button>
      </div>
    </form>
  </div>
</div>
