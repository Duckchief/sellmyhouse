<div id="compliance-cdd-card">
  <div class="flex items-center justify-between mb-4">
    <span class="px-2 py-1 text-xs rounded-full
      {% if compliance.cdd.status == 'verified' %}bg-green-100 text-green-800
      {% elif compliance.cdd.status == 'pending' %}bg-yellow-100 text-yellow-800
      {% else %}bg-gray-100 text-gray-800{% endif %}">{{ compliance.cdd.status | t }}</span>
  </div>

  {% if compliance.cdd.status == 'not_started' %}
    <p class="text-sm text-gray-500 mb-4">{{ "No CDD record exists for this seller." | t }}</p>
    <button
      type="button"
      hx-get="/agent/sellers/{{ sellerId }}/cdd/modal"
      hx-target="#compliance-modal-container"
      hx-swap="innerHTML"
      class="px-4 py-2 text-sm bg-indigo-600 text-white rounded hover:bg-indigo-700">
      {{ "Create CDD Record" | t }}
    </button>
  {% else %}
    <dl class="space-y-2 text-sm">
      {% if compliance.cdd.fullName %}
      <div class="flex justify-between">
        <dt class="text-gray-500">{{ "Name" | t }}</dt>
        <dd>{{ compliance.cdd.fullName }}</dd>
      </div>
      {% endif %}
      {% if compliance.cdd.nricLast4 %}
      <div class="flex justify-between">
        <dt class="text-gray-500">{{ "NRIC" | t }}</dt>
        <dd>SXXXX{{ compliance.cdd.nricLast4.substring(0, 3) }}{{ compliance.cdd.nricLast4.substring(3) }}</dd>
      </div>
      {% endif %}
      {% if compliance.cdd.riskLevel %}
      <div class="flex justify-between">
        <dt class="text-gray-500">{{ "Risk Level" | t }}</dt>
        <dd>
          <span class="px-2 py-0.5 text-xs rounded-full
            {% if compliance.cdd.riskLevel == 'enhanced' %}bg-orange-100 text-orange-800
            {% else %}bg-green-100 text-green-800{% endif %}">{{ compliance.cdd.riskLevel }}</span>
        </dd>
      </div>
      {% endif %}
      {% if compliance.cdd.verifiedAt %}
      <div class="flex justify-between">
        <dt class="text-gray-500">{{ "Verified" | t }}</dt>
        <dd>{{ compliance.cdd.verifiedAt | date }}</dd>
      </div>
      {% endif %}
    </dl>
  {% endif %}
</div>
