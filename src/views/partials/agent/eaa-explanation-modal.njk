<div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50" id="eaa-explanation-modal">
  <div class="bg-white rounded-lg shadow-xl p-6 w-96">
    <h3 class="text-lg font-semibold mb-4">{{ "Confirm EAA Explanation" | t }}</h3>

    <div id="explanation-modal-error" class="hidden mb-3 p-3 bg-red-50 text-red-700 text-sm rounded"></div>

    <form
      hx-post="/agent/eaa/{{ eaaId }}/explanation"
      hx-target="#compliance-eaa-card"
      hx-swap="outerHTML"
      data-remove-on-success="eaa-explanation-modal"
      data-error-target="explanation-modal-error"
      data-error-message="{{ 'An error occurred. Please try again.' | t }}"
    >
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-2">{{ "How were terms explained?" | t }} <span class="text-red-500">*</span></label>
          <div class="flex flex-col gap-2">
            <label class="inline-flex items-center">
              <input type="radio" name="method" value="video_call" required class="mr-2">
              <span class="text-sm">{{ "Video Call" | t }}</span>
            </label>
            <label class="inline-flex items-center">
              <input type="radio" name="method" value="in_person" class="mr-2">
              <span class="text-sm">{{ "In Person" | t }}</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">{{ "Notes" | t }}</label>
          <textarea name="notes" rows="3"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="{{ 'Optional notes about the explanation session' | t }}"></textarea>
        </div>
      </div>

      <div class="flex gap-3 justify-end mt-6">
        <button
          type="button"
          data-action="remove-element"
          data-target="eaa-explanation-modal"
          class="px-4 py-2 text-sm border rounded hover:bg-gray-50">
          {{ "Cancel" | t }}
        </button>
        <button
          type="submit"
          class="px-4 py-2 text-sm bg-indigo-600 text-white rounded hover:bg-indigo-700">
          {{ "Confirm Explanation" | t }}
        </button>
      </div>
    </form>
  </div>
</div>
