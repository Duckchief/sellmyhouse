{# src/views/partials/agent/pending-downloads.njk #}
{% if pendingDownloads and pendingDownloads.length > 0 %}
<div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
  <div class="flex items-start gap-3">
    <svg class="h-5 w-5 text-amber-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
    </svg>
    <div class="flex-1">
      <h3 class="text-sm font-semibold text-amber-800">
        {{ "{count} document(s) pending download" | t | replace("{count}", pendingDownloads.length) }}
      </h3>
      <p class="mt-1 text-xs text-amber-700">
        {{ "Documents are automatically deleted from the server after the retention period. Download and submit to Huttons' case submission system." | t }}
      </p>
      <ul class="mt-3 space-y-2">
        {% for item in pendingDownloads %}
        <li class="flex items-center justify-between text-sm">
          <div>
            <span class="font-medium text-gray-900">{{ item.propertyAddress }}</span>
            <span class="text-gray-500 ml-2">({{ item.docTypes | join(", ") }})</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs {% if item.daysRemaining <= 2 %}text-red-600 font-semibold{% else %}text-amber-700{% endif %}">
              {{ "{days} day(s) remaining" | t | replace("{days}", item.daysRemaining) }}
            </span>
            <a href="/agent/transactions/{{ item.transactionId }}/documents"
               class="text-xs font-medium text-blue-600 hover:text-blue-800 underline">
              {{ "Download" | t }}
            </a>
          </div>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>
{% endif %}
