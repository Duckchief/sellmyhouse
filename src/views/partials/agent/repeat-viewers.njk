{# partials/agent/repeat-viewers.njk #}
{% if repeatViewers and repeatViewers.length > 0 %}
<div class="mt-4 p-4 bg-blue-50 border border-blue-200 rounded">
  <h3 class="font-semibold text-blue-800 mb-2">{{ "Hot Leads — Repeat Viewers" | t }} ({{ repeatViewers.length }})</h3>
  <ul class="space-y-2 text-sm">
    {% for rv in repeatViewers %}
    <li class="flex justify-between items-center">
      <div>
        <span class="font-medium">{{ rv.viewerName }}</span>
        <span class="text-gray-500">({{ rv.viewerPhone }})</span>
      </div>
      <span class="text-blue-700 font-semibold">{{ rv.propertyCount }} {{ "properties viewed" | t }}</span>
    </li>
    {% endfor %}
  </ul>
</div>
{% endif %}
