{# src/views/partials/compliance/consent-withdrawal-result.njk #}
<div class="rounded-lg p-4 bg-green-50 border border-green-200">
  {% if type == 'marketing' %}
    <p class="text-sm font-medium text-green-800">{{ "Marketing consent withdrawn. You will no longer receive marketing communications." | t }}</p>
  {% else %}
    <p class="text-sm font-medium text-green-800">{{ "Service consent withdrawn. Your data will be processed for deletion according to our data retention schedule." | t }}</p>
  {% endif %}
</div>
