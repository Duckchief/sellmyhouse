{# FAQ Accordion Section #}
<section class="py-16 px-4 bg-[#fafaf7]">
  <h2 class="text-2xl font-bold text-center mb-10">{{ "Frequently Asked Questions" | t }}</h2>
  <div class="max-w-3xl mx-auto divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden" id="faq-accordion">

    {% set faqs = [
      {
        q: "How does the $1,499 fixed fee work?",
        a: "You pay a single flat fee of $1,499 + GST ($1,633.91) when your flat is successfully sold. No percentage commission, no upfront costs, no hidden charges. On a $500,000 flat, you save over $8,000 compared to a typical 2% commission."
      },
      {
        q: "Do I get a real agent or just AI?",
        a: "Both. Our AI tools handle the time-consuming work — pricing analysis, listing write-ups, and viewing scheduling. But a CEA-registered agent under Huttons Asia Pte Ltd reviews and approves everything before it reaches any buyer. You always have a licensed human in your corner."
      },
      {
        q: "When do I actually pay?",
        a: "Only when your flat is sold. There are no upfront fees and no charges if the transaction doesn't complete. You pay on successful completion."
      },
      {
        q: "Is my personal data safe?",
        a: "Yes. The platform is built to Singapore PDPA standards. Your data is used only to provide your selling service. We never sell your data, and we only send marketing communications if you explicitly opt in."
      },
      {
        q: "How long does the HDB resale process take?",
        a: "Typically 3–6 months from listing to completion, depending on HDB processing times and how quickly a buyer is found. We guide you at every stage and keep you updated throughout."
      },
      {
        q: "What happens after I submit my details?",
        a: "An agent will contact you within 24 hours to discuss your flat and goals. We'll then prepare a free HDB market report and walk you through the next steps."
      },
      {
        q: "How is my flat priced?",
        a: "We analyse recent HDB resale transactions in your block, floor range, and town using live HDB data. Your agent reviews the AI-generated pricing analysis and works with you to set a competitive asking price."
      },
      {
        q: "Do I need to handle the HDB paperwork myself?",
        a: "No. Your agent handles the HDB resale submission, coordinates with HDB, and manages the transaction paperwork. You'll be kept informed at each milestone via WhatsApp or email."
      },
      {
        q: "Can I withdraw at any time?",
        a: "Yes. There's no lock-in period before you sign the Option to Purchase. If your circumstances change, simply let your agent know."
      },
      {
        q: "What if my flat doesn't sell?",
        a: "You pay nothing. Our fixed fee is only due on successful completion. There are no charges if the sale does not go through."
      }
    ] %}

    {% for item in faqs %}
    <div class="faq-item bg-white">
      <button
        type="button"
        class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left font-semibold text-[#1a1a2e] hover:bg-gray-50 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[#c8553d]"
        aria-expanded="{{ 'true' if loop.first else 'false' }}"
      >
        <span>{{ item.q | t }}</span>
        <svg class="faq-chevron w-5 h-5 text-[#c8553d] flex-shrink-0 ml-4 transition-transform duration-200 {{ 'rotate-180' if loop.first else '' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div class="faq-panel overflow-hidden transition-all duration-200 ease-in-out {{ '' if loop.first else 'hidden' }}">
        <p class="px-6 pb-5 text-sm text-gray-600 leading-relaxed">{{ item.a | t }}</p>
      </div>
    </div>
    {% endfor %}

  </div>
</section>

<script>
(function () {
  var accordion = document.getElementById('faq-accordion');
  if (!accordion) return;

  accordion.addEventListener('click', function (e) {
    var trigger = e.target.closest('.faq-trigger');
    if (!trigger) return;

    var item = trigger.closest('.faq-item');
    var panel = item.querySelector('.faq-panel');
    var chevron = item.querySelector('.faq-chevron');
    var isOpen = trigger.getAttribute('aria-expanded') === 'true';

    // Close all
    accordion.querySelectorAll('.faq-item').forEach(function (otherItem) {
      var otherTrigger = otherItem.querySelector('.faq-trigger');
      var otherPanel = otherItem.querySelector('.faq-panel');
      var otherChevron = otherItem.querySelector('.faq-chevron');
      otherTrigger.setAttribute('aria-expanded', 'false');
      otherPanel.classList.add('hidden');
      otherChevron.classList.remove('rotate-180');
    });

    // Open clicked if it was closed
    if (!isOpen) {
      trigger.setAttribute('aria-expanded', 'true');
      panel.classList.remove('hidden');
      chevron.classList.add('rotate-180');
    }
  });
}());
</script>
