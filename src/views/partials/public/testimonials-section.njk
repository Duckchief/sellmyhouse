<section class="py-16 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-center mb-10">{{ "What Our Sellers Say" | t }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for t in testimonials %}
      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center gap-1 mb-3">
          {% for i in range(0, t.rating) %}
          <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <p class="text-gray-700 text-sm mb-4 italic">"{{ t.content }}"</p>
        <p class="text-sm font-medium text-gray-800">{{ t.sellerName }}</p>
        <p class="text-xs text-gray-400">{{ t.sellerTown }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
