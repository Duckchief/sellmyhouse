{% if error %}
<p class="text-red-600 text-sm">{{ error }}</p>
{% else %}
<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="text-left text-gray-400 border-b border-gray-200">
        <th class="pb-2 pr-4 font-medium">{{ "Transaction Date" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Block" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Street" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Storey" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Flat Type" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Floor Area" | t }}</th>
        <th class="pb-2 pr-4 font-medium">{{ "Lease Start" | t }}</th>
        <th class="pb-2 text-right font-medium">{{ "Price" | t }}</th>
      </tr>
    </thead>
    <tbody>
      {% for txn in transactions %}
      <tr class="border-b border-gray-100">
        <td class="py-2 pr-4">{{ txn.month | formatMonth }}</td>
        <td class="py-2 pr-4">{{ txn.block }}</td>
        <td class="py-2 pr-4">{{ txn.streetName }}</td>
        <td class="py-2 pr-4">{{ txn.storeyRange }}</td>
        <td class="py-2 pr-4">{{ txn.flatType }}</td>
        <td class="py-2 pr-4">{{ txn.floorAreaSqm }} sqm</td>
        <td class="py-2 pr-4">{{ txn.leaseCommenceDate }}</td>
        <td class="py-2 text-right text-[#c8553d] font-semibold">S${{ txn.resalePrice | formatPrice }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% if totalPages > 1 %}
<div class="flex items-center justify-between text-sm mt-3">
  <span class="text-gray-500">{{ "Page" | t }} {{ page }} {{ "of" | t }} {{ totalPages }} ({{ total }} {{ "transactions" | t }})</span>
  <div class="flex gap-2">
    {% if page > 1 %}
    <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50"
            hx-get="/api/hdb/transactions"
            hx-vals='{"page": {{ page - 1 }}}'
            hx-include="#market-report-form"
            hx-target="#transactions-table"
            hx-swap="innerHTML">{{ "← Prev" | t }}</button>
    {% endif %}
    {% if page < totalPages %}
    <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50"
            hx-get="/api/hdb/transactions"
            hx-vals='{"page": {{ page + 1 }}}'
            hx-include="#market-report-form"
            hx-target="#transactions-table"
            hx-swap="innerHTML">{{ "Next →" | t }}</button>
    {% endif %}
  </div>
</div>
{% endif %}
{% endif %}
