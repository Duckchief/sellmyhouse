{#
  Variables: reports (FinancialReport[])
  HTMX partial — renders into #financial-history on the financial page.
  Each row triggers an HTMX GET to load the full report into #financial-content.
#}
{% if not reports or reports.length == 0 %}
<p class="text-xs text-gray-400 text-center py-4">{{ "No reports yet." | t }}</p>
{% else %}
<ul class="divide-y divide-gray-100 -mx-4">
  {% for report in reports %}
  {% set data = report.reportData %}
  <li>
    <button
      type="button"
      hx-get="/seller/financial/report/{{ report.id }}"
      hx-target="#financial-content"
      hx-swap="innerHTML"
      class="w-full text-left px-4 py-3 hover:bg-gray-50 transition"
    >
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-gray-900 truncate">
            {% if data.metadata.town %}{{ data.metadata.town }} · {% endif %}{{ data.metadata.flatType }}
          </p>
          <p class="text-xs text-gray-800 font-semibold mt-0.5">
            ${{ data.outputs.netCashProceeds }}
          </p>
          <p class="text-xs text-gray-400 mt-0.5">
            {{ data.metadata.calculatedAt | date }}
          </p>
        </div>
        <div class="flex-shrink-0 flex flex-col items-end gap-1">
          <span class="text-xs text-gray-400">v{{ report.version }}</span>
          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium
            {% if report.status == 'sent' %}bg-green-100 text-green-700
            {% elif report.status == 'approved' %}bg-blue-100 text-blue-700
            {% elif report.status == 'pending_review' %}bg-yellow-100 text-yellow-700
            {% else %}bg-gray-100 text-gray-600{% endif %}">
            {{ report.status | t }}
          </span>
        </div>
      </div>
    </button>
  </li>
  {% endfor %}
</ul>
{% endif %}
