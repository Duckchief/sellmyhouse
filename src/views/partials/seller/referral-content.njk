<div class="bg-white border border-gray-200 rounded-xl p-6">
  <div class="mb-4">
    <p class="text-sm text-gray-500 mb-1">{{ "Your referral link" | t }}</p>
    <div class="flex items-center gap-2">
      <input type="text" readonly
        value="{{ baseUrl }}/?ref={{ referral.referralCode }}"
        class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 font-mono"
        id="referral-link-input">
      <button
        onclick="navigator.clipboard.writeText(document.getElementById('referral-link-input').value)"
        class="bg-indigo-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-indigo-700 flex-shrink-0">
        {{ "Copy" | t }}
      </button>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-4 text-center mt-6">
    <div>
      <p class="text-2xl font-bold">{{ referral.clickCount }}</p>
      <p class="text-xs text-gray-400">{{ "Link Clicks" | t }}</p>
    </div>
    <div>
      <p class="text-2xl font-bold">{{ "1" if referral.referredSellerId else "0" }}</p>
      <p class="text-xs text-gray-400">{{ "Leads Created" | t }}</p>
    </div>
    <div>
      <p class="text-2xl font-bold">{{ "1" if referral.status == "transaction_completed" else "0" }}</p>
      <p class="text-xs text-gray-400">{{ "Completed" | t }}</p>
    </div>
  </div>
</div>
