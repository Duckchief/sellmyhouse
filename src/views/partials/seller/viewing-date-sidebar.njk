{#
  Variables (from getSlotsForDate):
    date: string (YYYY-MM-DD)
    slots: { id, startTime, endTime, slotType, maxViewers, currentBookings, status }[]
    suggestedStart: string (HH:MM)
    suggestedEnd: string (HH:MM)
    propertyId: string (from query param, forwarded by router)
#}

{# Schedule for the selected date — shown in sidebar #}
<div class="p-4">
  <h3 class="text-sm font-semibold text-gray-900 mb-3">{{ date }}</h3>

  <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">{{ "Schedule" | t }}</p>
  {% if slots.length > 0 %}
  <div class="space-y-1.5">
    {% for slot in slots %}
    <div class="flex items-center gap-3 text-xs bg-gray-50 rounded px-2.5 py-1.5" data-slot-id="{{ slot.id }}">
      {% if slot.status == 'full' or (slot.slotType == 'single' and slot.currentBookings >= 1) %}
        <span class="w-2 h-2 rounded-full bg-red-500 shrink-0" title="{{ 'Full' | t }}"></span>
      {% else %}
        <span class="w-2 h-2 rounded-full bg-green-500 shrink-0" title="{{ 'Available' | t }}"></span>
      {% endif %}
      <span class="font-medium text-gray-700 flex-1">{{ slot.startTime }}–{{ slot.endTime }}</span>
      <span class="text-gray-500">{{ slot.slotType | capitalize }}</span>
      {% if slot.status != 'cancelled' %}
      <button type="button"
              data-action="open-cancel-slot-modal"
              data-slot-id="{{ slot.id }}"
              class="shrink-0 text-gray-400 hover:text-red-600 transition"
              title="{{ 'Cancel slot' | t }}">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-xs text-gray-400">{{ "No slots yet" | t }}</p>
  {% endif %}
</div>
