{#
  Variables:
    stats: ViewingStatsResult | null
      { totalViewings, upcomingCount, averageInterestRating, noShowCount }
    slots: ViewingSlot[] (with slot.viewings[].verifiedViewer, next 30 days)
    propertyId: string | undefined
#}

{# ── Stats row ───────────────────────────────────────────── #}
{% if stats %}
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-gray-900">{{ stats.totalViewings }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "Total Viewings" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-blue-600">{{ stats.upcomingCount }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "Upcoming" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-green-600">
      {% if stats.averageInterestRating %}{{ stats.averageInterestRating | round(1) }}{% else %}–{% endif %}
    </p>
    <p class="text-xs text-gray-500 mt-1">{{ "Avg. Interest" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-red-500">{{ stats.noShowCount }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "No-shows" | t }}</p>
  </div>
</div>
{% endif %}

{# ── Add slot forms ──────────────────────────────────────── #}
<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="font-semibold text-gray-900 mb-2">{{ "Add Viewing Slots" | t }}</h2>
  <p class="text-xs text-gray-400 mb-4">{{ "Viewing hours: 10:00 AM – 8:00 PM. Maximum 10 slots per day, 200 active slots total." | t }}</p>

  {# Tab toggle #}
  <div class="flex gap-2 mb-4 border-b border-gray-200">
    <button type="button" id="tab-single"
            data-action="show-viewing-tab" data-tab="single"
            class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 -mb-px">
      {{ "Single Slot" | t }}
    </button>
    <button type="button" id="tab-bulk"
            data-action="show-viewing-tab" data-tab="bulk"
            class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 -mb-px">
      {{ "Recurring Slots" | t }}
    </button>
  </div>

  {# Single slot — left: calendar + add form, right: day schedule #}
  <div id="panel-single" class="flex flex-col sm:flex-row gap-0">
    {# Left column: calendar + add form #}
    <div class="w-full sm:w-[40%] sm:border-r border-gray-200 sm:pr-4">
      <div id="viewing-calendar"
           data-property-id="{{ propertyId }}"
           data-slots-by-date='{{ slotsByDate | dump | safe }}'
           data-sidebar-target="#date-sidebar"
      ></div>

      {# Add new slot form — hidden until date selected #}
      <div id="add-slot-section" class="hidden border-t border-gray-200 mt-4 pt-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">{{ "Add New Slot" | t }}</p>
        <form
          id="add-slot-form"
          hx-post="/seller/viewings/slots"
          hx-target="#slots-list"
          hx-swap="beforeend"
          class="space-y-2"
        >
          <input type="hidden" name="propertyId" value="{{ propertyId }}">
          <input type="hidden" id="add-slot-date" name="date" value="">

          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Date" | t }}</label>
            <input type="text" id="add-slot-date-display" readonly
                   class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-sm bg-gray-50 text-gray-700">
          </div>
          <div class="flex gap-2">
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Start" | t }}</label>
              <input type="time" id="add-slot-start" name="startTime" min="10:00" max="20:00" required
                     class="viewing-time-input w-full px-2 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-700 mb-1">{{ "End" | t }}</label>
              <input type="time" id="add-slot-end" name="endTime" min="10:00" max="20:00" required
                     class="viewing-time-input w-full px-2 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div class="viewing-time-error hidden text-xs text-red-600 -mt-1">{{ "Viewing times must be between 10:00 AM and 8:00 PM." | t }}</div>
          <div class="flex gap-2">
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Type" | t }}</label>
              <select name="slotType"
                      class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="single">{{ "Single viewer" | t }}</option>
                <option value="group">{{ "Open house" | t }}</option>
              </select>
            </div>
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Max viewers" | t }}</label>
              <input type="number" name="maxViewers" min="2" max="20" placeholder="2"
                     class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <button type="submit"
                  class="w-full px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition">
            {{ "Add Slot" | t }}
          </button>
          <div id="add-slot-error"></div>
        </form>
      </div>
    </div>

    {# Right column: day schedule #}
    <div id="date-sidebar" class="w-full sm:w-[60%] sm:pl-4 min-h-[120px] max-h-[500px] overflow-y-auto flex items-start justify-center">
      <p class="text-sm text-gray-400 text-center">{{ "Select a date on the calendar." | t }}</p>
    </div>
  </div>

  {# Recurring slots form #}
  <div id="panel-bulk" class="hidden">
    <div class="flex flex-col sm:flex-row gap-4 mb-4">
      {# Start date calendar #}
      <div class="w-full sm:w-[40%]">
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Start Date" | t }}</label>
        <div id="bulk-start-calendar" data-target-input="#bulk-start-date"></div>
      </div>
      {# Divider #}
      <div class="hidden sm:block w-px bg-gray-200"></div>
      {# End date calendar #}
      <div class="w-full sm:w-[40%]">
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "End Date" | t }}</label>
        <div id="bulk-end-calendar" data-target-input="#bulk-end-date"></div>
      </div>
    </div>

    <form
      id="recurring-slots-form"
      hx-post="/seller/viewings/slots"
      hx-target="#bulk-result"
      hx-swap="innerHTML"
      data-reset-on-success
      class="grid grid-cols-1 sm:grid-cols-2 gap-4"
    >
      <input type="hidden" name="propertyId" value="{{ propertyId }}">
      <input type="hidden" name="bulk" value="true">
      <input type="hidden" id="bulk-start-date" name="startDate" value="">
      <input type="hidden" id="bulk-end-date" name="endDate" value="">

      <div class="sm:col-span-2">
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Selected Range" | t }}</label>
        <div class="flex gap-2">
          <input type="text" id="bulk-start-display" readonly placeholder="{{ 'Start date' | t }}"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-md text-sm bg-gray-50 text-gray-700">
          <span class="self-center text-gray-400">→</span>
          <input type="text" id="bulk-end-display" readonly placeholder="{{ 'End date' | t }}"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-md text-sm bg-gray-50 text-gray-700">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Day of Week" | t }}</label>
        <select name="dayOfWeek" required
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="0">{{ "Sunday" | t }}</option>
          <option value="1">{{ "Monday" | t }}</option>
          <option value="2">{{ "Tuesday" | t }}</option>
          <option value="3">{{ "Wednesday" | t }}</option>
          <option value="4">{{ "Thursday" | t }}</option>
          <option value="5">{{ "Friday" | t }}</option>
          <option value="6">{{ "Saturday" | t }}</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Slot Duration (minutes)" | t }}</label>
        <input type="number" name="slotDurationMinutes" value="10" min="10" max="120" required
               class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Window Start" | t }}</label>
        <input type="time" name="startTime" min="10:00" max="20:00" required
               class="viewing-time-input w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Window End" | t }}</label>
        <input type="time" name="endTime" min="10:00" max="20:00" required
               class="viewing-time-input w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="viewing-time-error hidden text-xs text-red-600 sm:col-span-2 -mt-2">{{ "Viewing times must be between 10:00 AM and 8:00 PM." | t }}</div>
      <div class="sm:col-span-2">
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Type" | t }}</label>
        <select name="slotType"
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="single">{{ "Single viewer" | t }}</option>
          <option value="group">{{ "Open house" | t }}</option>
        </select>
      </div>
      <div class="sm:col-span-2">
        <button type="submit"
                class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition">
          {{ "Create Recurring Slots" | t }}
        </button>
      </div>
    </form>
    <div id="bulk-result" class="mt-3"></div>
  </div>
</div>

{# ── Slot list (next 30 days) ────────────────────────────── #}
<div class="bg-white rounded-lg shadow p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-semibold text-gray-900">{{ "Upcoming Slots" | t }}</h2>
    <div class="flex items-center gap-3">
      <label class="flex items-center gap-1.5 text-xs text-gray-500 cursor-pointer">
        <input type="checkbox" id="select-all-slots"
               class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
        {{ "Select all" | t }}
      </label>
      <button type="button" id="delete-selected-slots"
              class="hidden px-3 py-1.5 bg-red-600 text-white text-xs font-medium rounded-md hover:bg-red-700 transition">
        {{ "Delete selected" | t }}
      </button>
    </div>
  </div>

  <div id="slots-list" class="space-y-3">
    {% if not slots or slots.length == 0 %}
    <p class="text-sm text-gray-500 text-center py-4">{{ "No slots scheduled in the next 30 days." | t }}</p>
    {% else %}
    {% for slot in slots %}
    {% include "partials/seller/slot-row.njk" %}
    {% endfor %}

    {% if hasMore %}
    <div id="load-more-slots" class="text-center pt-2">
      <button type="button"
              hx-get="/seller/viewings?propertyId={{ propertyId }}&page={{ page + 1 }}"
              hx-target="#load-more-slots"
              hx-swap="outerHTML"
              class="px-4 py-2 text-sm text-blue-600 hover:text-blue-800 font-medium">
        {{ "Load more" | t }}
      </button>
    </div>
    {% endif %}
    {% endif %}
  </div>

  {% if totalSlots %}
  <p class="text-xs text-gray-400 mt-3 text-right">{{ "Showing" | t }} {{ slots.length }} {{ "of" | t }} {{ totalSlots }} {{ "slots" | t }}</p>
  {% endif %}
</div>


