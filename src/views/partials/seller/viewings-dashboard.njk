{#
  Variables:
    stats: ViewingStatsResult | null
      { totalViewings, upcomingCount, averageInterestRating, noShowCount }
    slots: ViewingSlot[] (with slot.viewings[].verifiedViewer, next 30 days)
    propertyId: string | undefined
#}

{# ── Stats row ───────────────────────────────────────────── #}
{% if stats %}
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-gray-900">{{ stats.totalViewings }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "Total Viewings" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-blue-600">{{ stats.upcomingCount }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "Upcoming" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-green-600">
      {% if stats.averageInterestRating %}{{ stats.averageInterestRating | round(1) }}{% else %}–{% endif %}
    </p>
    <p class="text-xs text-gray-500 mt-1">{{ "Avg. Interest" | t }}</p>
  </div>
  <div class="bg-white rounded-lg shadow p-4 text-center">
    <p class="text-2xl font-bold text-red-500">{{ stats.noShowCount }}</p>
    <p class="text-xs text-gray-500 mt-1">{{ "No-shows" | t }}</p>
  </div>
</div>
{% endif %}

{# ── Add slot forms ──────────────────────────────────────── #}
<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="font-semibold text-gray-900 mb-4">{{ "Add Viewing Slots" | t }}</h2>

  {# Tab toggle #}
  <div class="flex gap-2 mb-4 border-b border-gray-200">
    <button type="button" id="tab-single"
            data-action="show-viewing-tab" data-tab="single"
            class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 -mb-px">
      {{ "Single Slot" | t }}
    </button>
    <button type="button" id="tab-bulk"
            data-action="show-viewing-tab" data-tab="bulk"
            class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 -mb-px">
      {{ "Bulk (Recurring)" | t }}
    </button>
  </div>

  {# Single slot form — calendar + sidebar layout #}
  <div id="panel-single" class="flex flex-col sm:flex-row gap-0">
    {# Calendar (60%) #}
    <div class="w-full sm:w-[60%] sm:border-r border-gray-200 sm:pr-4">
      <div id="viewing-calendar"
           data-property-id="{{ propertyId }}"
           data-slots-by-date="{{ slotsByDate | dump | safe }}"
           data-sidebar-target="#date-sidebar"
      ></div>
    </div>

    {# Sidebar (40%) #}
    <div id="date-sidebar" class="w-full sm:w-[40%] sm:pl-4 min-h-[200px] flex items-center justify-center">
      <p class="text-sm text-gray-400 text-center">{{ "Select a date on the calendar to add a viewing slot." | t }}</p>
    </div>
  </div>

  {# Bulk slot form #}
  <div id="panel-bulk" class="hidden">
    <form
      hx-post="/seller/viewings/slots"
      hx-target="#bulk-result"
      hx-swap="innerHTML"
      data-reset-on-success
      class="grid grid-cols-1 sm:grid-cols-2 gap-4"
    >
      <input type="hidden" name="propertyId" value="{{ propertyId }}">
      <input type="hidden" name="bulk" value="true">

      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Start Date" | t }}</label>
        <input type="date" name="startDate" required
               class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "End Date" | t }}</label>
        <input type="date" name="endDate" required
               class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Day of Week" | t }}</label>
        <select name="dayOfWeek" required
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="0">{{ "Sunday" | t }}</option>
          <option value="1">{{ "Monday" | t }}</option>
          <option value="2">{{ "Tuesday" | t }}</option>
          <option value="3">{{ "Wednesday" | t }}</option>
          <option value="4">{{ "Thursday" | t }}</option>
          <option value="5">{{ "Friday" | t }}</option>
          <option value="6">{{ "Saturday" | t }}</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Slot Duration (minutes)" | t }}</label>
        <input type="number" name="slotDurationMinutes" value="15" min="5" max="120" required
               class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="flex gap-2">
        <div class="flex-1">
          <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Window Start" | t }}</label>
          <input type="time" name="startTime" required
                 class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div class="flex-1">
          <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Window End" | t }}</label>
          <input type="time" name="endTime" required
                 class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">{{ "Type" | t }}</label>
        <select name="slotType"
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="single">{{ "Single viewer" | t }}</option>
          <option value="group">{{ "Group viewing" | t }}</option>
        </select>
      </div>
      <div class="sm:col-span-2">
        <button type="submit"
                class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition">
          {{ "Create Recurring Slots" | t }}
        </button>
      </div>
    </form>
    <div id="bulk-result" class="mt-3"></div>
  </div>
</div>

{# ── Slot list (next 30 days) ────────────────────────────── #}
<div class="bg-white rounded-lg shadow p-6">
  <h2 class="font-semibold text-gray-900 mb-4">{{ "Upcoming Slots" | t }}</h2>

  {% if not slots or slots.length == 0 %}
  <p class="text-sm text-gray-500 text-center py-4">{{ "No slots scheduled in the next 30 days." | t }}</p>
  {% else %}
  <div id="slots-list" class="space-y-3">
    {% for slot in slots %}
    {% include "partials/seller/slot-row.njk" %}
    {% endfor %}
  </div>
  {% endif %}
</div>


