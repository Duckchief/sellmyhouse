{% extends "layouts/public.njk" %}

{% block content %}
<div class="max-w-lg mx-auto">
  <div class="bg-white rounded-lg shadow p-8 text-center">
    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <h1 class="text-xl font-bold text-gray-900 mb-2">{{ "Viewing Cancelled" | t }}</h1>
    <p class="text-gray-600 text-sm">
      {{ "Your viewing appointment has been successfully cancelled. If you change your mind, please visit the booking page to select a new time." | t }}
    </p>
    <div class="mt-6">
      <a href="/" class="text-blue-600 text-sm hover:underline">{{ "Return to homepage" | t }}</a>
    </div>
  </div>
</div>
{% endblock %}
