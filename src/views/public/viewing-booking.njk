{% extends "layouts/public.njk" %}

{% block content %}
<div class="max-w-2xl mx-auto">
  {# Property header #}
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">
      {{ "Book a Viewing" | t }}
    </h1>
    <p class="mt-1 text-gray-600">
      {{ property.block }} {{ property.street }}, {{ property.town }}
    </p>
  </div>

  {% if not slots or slots.length == 0 %}
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
    <p class="text-yellow-800 font-medium">{{ "No viewing slots are currently available." | t }}</p>
    <p class="text-yellow-700 text-sm mt-1">{{ "Please check back soon or contact the agent." | t }}</p>
  </div>
  {% else %}

  <div id="booking-area">
    <form
      hx-post="/view/{{ property.slug }}/book"
      hx-target="#booking-area"
      hx-swap="innerHTML"
      hx-indicator="#booking-spinner"
    >
      {# Honeypot — hidden from real users, filled by bots #}
      <input type="text" name="website" value="" tabindex="-1" autocomplete="off"
             class="absolute opacity-0 pointer-events-none w-0 h-0" aria-hidden="true">

      {# Timing honeypot #}
      <input type="hidden" name="formLoadedAt" value="{{ formLoadedAt }}">

      {# ── Step 1: Slot picker ─────────────────────────────── #}
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <h2 class="font-semibold text-gray-900 mb-4">{{ "Select a Time Slot" | t }}</h2>
        <div class="space-y-2" id="slot-list">
          {% for slot in slots %}
          <label class="flex items-center gap-3 p-3 rounded-md border border-gray-200 cursor-pointer hover:bg-blue-50 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50">
            <input type="radio" name="slotId" value="{{ slot.id }}" required
                   class="h-4 w-4 text-blue-600 border-gray-300">
            <div class="flex-1">
              <span class="font-medium text-gray-900 text-sm">
                {{ slot.date | date }}
              </span>
              <span class="text-gray-600 text-sm ml-2">
                {{ slot.startTime }} – {{ slot.endTime }}
              </span>
              {% if slot.slotType == 'group' %}
              <span class="ml-2 text-xs text-gray-500">
                ({{ "Group viewing" | t }} · {{ slot.maxViewers - slot.currentBookings }} {{ "spots left" | t }})
              </span>
              {% endif %}
            </div>
          </label>
          {% endfor %}
        </div>
      </div>

      {# ── Step 2: Viewer details ──────────────────────────── #}
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <h2 class="font-semibold text-gray-900 mb-4">{{ "Your Details" | t }}</h2>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="name">
              {{ "Full Name" | t }} <span class="text-red-500">*</span>
            </label>
            <input type="text" id="name" name="name" required autocomplete="name"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="phone">
              {{ "Singapore Mobile Number" | t }} <span class="text-red-500">*</span>
            </label>
            <input type="tel" id="phone" name="phone" required autocomplete="tel"
                   placeholder="e.g. 91234567"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <p class="mt-1 text-xs text-gray-500">{{ "8 digits, starting with 8 or 9. A verification code will be sent." | t }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {{ "I am a" | t }} <span class="text-red-500">*</span>
            </label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="viewerType" value="buyer" required
                       class="h-4 w-4 text-blue-600"
                       data-action="toggle-agent-fields" data-show="false"
                <span class="text-sm text-gray-700">{{ "Buyer / Interested Party" | t }}</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="viewerType" value="agent" required
                       class="h-4 w-4 text-blue-600"
                       data-action="toggle-agent-fields" data-show="true"
                <span class="text-sm text-gray-700">{{ "Property Agent" | t }}</span>
              </label>
            </div>
          </div>

          {# Agent-only fields — hidden by default #}
          <div id="agent-fields" class="hidden space-y-4 pl-4 border-l-2 border-blue-200">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="agentName">
                {{ "Agent Full Name" | t }} <span class="text-red-500">*</span>
              </label>
              <input type="text" id="agentName" name="agentName" autocomplete="name"
                     class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="agentCeaReg">
                {{ "CEA Registration Number" | t }} <span class="text-red-500">*</span>
              </label>
              <input type="text" id="agentCeaReg" name="agentCeaReg"
                     class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="agentAgencyName">
                {{ "Agency Name" | t }} <span class="text-red-500">*</span>
              </label>
              <input type="text" id="agentAgencyName" name="agentAgencyName"
                     class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
        </div>
      </div>

      {# ── Step 3: Consent ─────────────────────────────────── #}
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" name="consentService" value="true" required
                 class="mt-0.5 h-4 w-4 text-blue-600 border-gray-300 rounded">
          <span class="text-sm text-gray-700">
            {{ "I consent to SellMyHomeNow contacting me in connection with this property viewing request. I understand my information will be processed in accordance with the" | t }}
            <a href="/privacy" class="text-blue-600 hover:underline">{{ "Privacy Policy" | t }}</a>.
            <span class="text-red-500">*</span>
          </span>
        </label>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit"
                class="px-6 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
          {{ "Request Viewing" | t }}
        </button>
        <span id="booking-spinner" class="htmx-indicator text-sm text-gray-500">
          {{ "Submitting…" | t }}
        </span>
      </div>
    </form>
  </div>
  {% endif %}
</div>
{% endblock %}
